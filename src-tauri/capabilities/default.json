{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "global-shortcut:allow-register-all",
    "shell:default",
    "shell:allow-execute",
    "core:window:allow-start-dragging",
    "core:window:allow-start-resize-dragging"
  ]
}
